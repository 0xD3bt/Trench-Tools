# ============================================================
# Trench Tools practical starter setup
# ============================================================
#
# Copy this file to `.env` and fill in the values below.
# This is intentionally short. Advanced tuning lives in `.env.advanced`.
#
# Never commit your real `.env`.

# ------------------------------------------------------------
# Voluntary Trench Tools fee
# ------------------------------------------------------------
#
# Trench Tools has a voluntary fee on supported trade paths.
# Blank/default = 0.1%.
# Set 0 to turn it off.
# Set 0.2 to increase support to 0.2%.
#
# If Trench Tools saves you time and money, consider leaving the
# default 0.1% on. It helps support development and future tools.
TRENCH_TOOL_FEE=

# ------------------------------------------------------------
# Launcher
# ------------------------------------------------------------
#
# blank = both
# ee    = execution-engine only (extension trading + PnL)
# ld    = LaunchDeck only (launchdeck-engine + follow daemon)
# both  = full stack
TRENCH_TOOLS_MODE=

# ------------------------------------------------------------
# Wallets
# ------------------------------------------------------------
#
# Format:
# SOLANA_PRIVATE_KEY=<privatekey>
# SOLANA_PRIVATE_KEY2=<privatekey>,<tag>
#
# Tagged examples:
# SOLANA_PRIVATE_KEY=YOUR_PRIVATE_KEY,Main Wallet
# SOLANA_PRIVATE_KEY2=YOUR_PRIVATE_KEY,Sniper 2
#
# You can add more wallets with the same pattern:
# SOLANA_PRIVATE_KEY3, SOLANA_PRIVATE_KEY4, ...
SOLANA_PRIVATE_KEY=
SOLANA_PRIVATE_KEY2=
SOLANA_PRIVATE_KEY3=
SOLANA_PRIVATE_KEY4=
SOLANA_PRIVATE_KEY5=

# ------------------------------------------------------------
# Core RPC / websocket
# ------------------------------------------------------------
#
# Main Solana HTTP RPC used for reads, confirmations, and runtime behavior.
# Recommended: Helius Gatekeeper HTTP.
# Copy this exact format and replace only YOUR_HELIUS_API_KEY:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_RPC_URL=

# Main Solana websocket used for live watchers.
# Recommended: Helius standard websocket.
# Copy this exact format and replace only YOUR_HELIUS_API_KEY:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_WS_URL=

# Default region profile for region-aware providers.
# Groups: global, us, eu, asia
# Metros: slc, ewr, lon, fra, ams, sg, tyo
# Examples:
# USER_REGION=eu
# USER_REGION=fra
# USER_REGION=fra,ams
USER_REGION=

# Optional low-priority RPC used for startup warmup, keep-warm probes,
# and block-height reads. Leave blank to reuse SOLANA_RPC_URL.
# Recommended: use a separate Shyft RPC so warm traffic does not drain
# your main Helius budget:
#   https://rpc.shyft.to?api_key=YOUR_SHYFT_API_KEY
WARM_RPC_URL=

# Optional low-priority websocket for non-critical balance/account subscriptions.
# Leave blank to reuse SOLANA_WS_URL.
# Example:
#   wss://rpc.shyft.to?api_key=YOUR_SHYFT_API_KEY
WARM_WS_URL=

# ------------------------------------------------------------
# Optional provider / launchpad keys
# ------------------------------------------------------------

# Optional Hello Moon Lunar Lander API key.
# Only needed if you want to use the Hello Moon provider.
HELLOMOON_API_KEY=

# Optional Bags API key.
# Only needed if you use Bags launchpad flows.
BAGS_API_KEY=

# LaunchDeck report timing detail.
# Supported: off, light, full. Blank/default = full.
LAUNCHDECK_BENCHMARK_MODE=

# ------------------------------------------------------------
# Optional metadata upload
# ------------------------------------------------------------
#
# Blank/default uses pump-fun metadata upload.
# Set `pinata` if you want Pinata-backed metadata uploads.
LAUNCHDECK_METADATA_UPLOAD_PROVIDER=

# Required only when LAUNCHDECK_METADATA_UPLOAD_PROVIDER=pinata.
# Get it from https://pinata.cloud/
PINATA_JWT=

