# ============================================================
# Trench Tools advanced environment reference
# ============================================================
#
# Start from `.env.example`. Copy values from this file only when you
# intentionally need to override the default behavior.
#
# The unified launchers already set sensible defaults for ports, logs, and
# local state paths. Most users should leave this file alone.

# ------------------------------------------------------------
# Launcher / host overrides
# ------------------------------------------------------------

# ee | ld | both. Blank defaults to both.
TRENCH_TOOLS_MODE=

# Windows launcher only: none | logs.
# Default: none.
TRENCH_TOOLS_TERMINALS=none

# Shared local data root used by the launchers.
# Default: .local/trench-tools
TRENCH_TOOLS_DATA_ROOT=

# Default ports.
EXECUTION_ENGINE_PORT=
LAUNCHDECK_PORT=
LAUNCHDECK_FOLLOW_DAEMON_PORT=

# Default log directory.
# Default: .local/logs
LOG_DIR=

# ------------------------------------------------------------
# Wallets
# ------------------------------------------------------------

# Primary keypair path override for flows that support filesystem keypairs.
SOLANA_KEYPAIR_PATH=

# Wallet private-key slots are open-ended:
# SOLANA_PRIVATE_KEY=
# SOLANA_PRIVATE_KEY2=
# SOLANA_PRIVATE_KEY3=

# ------------------------------------------------------------
# Core Solana RPC / websocket
# ------------------------------------------------------------

# Main HTTP RPC and websocket should normally be set in `.env`.
SOLANA_RPC_URL=
SOLANA_WS_URL=

# Optional Helius HTTP override used for priority-fee estimates.
# In most setups this is not needed because a Helius SOLANA_RPC_URL is detected.
HELIUS_RPC_URL=

# Optional Helius websocket override used for transactionSubscribe watchers.
# In most setups this is not needed because a Helius SOLANA_WS_URL is detected.
HELIUS_WS_URL=

# Optional submit-only RPC fanout for the deferred Standard RPC provider path.
# Not recommended as a default provider while it is pending re-validation.
LAUNCHDECK_EXTRA_STANDARD_RPC_SEND_URLS=

# Low-priority warm/cache paths. When set, compatible best-effort probes can
# move off the primary SOLANA_RPC_URL / SOLANA_WS_URL. Visible wallet, quote,
# execution, send, and confirmation paths stay on primary. Blank values keep
# Helius-only warm behavior.
WARM_RPC_URL=
WARM_WS_URL=

# ------------------------------------------------------------
# Region / provider routing
# ------------------------------------------------------------

# Shared default region for region-aware providers.
# Groups: global, us, eu, asia. Metros: slc, ewr, lon, fra, ams, sg, tyo.
USER_REGION=

# Provider-specific region overrides.
USER_REGION_HELIUS_SENDER=
USER_REGION_HELLOMOON=
USER_REGION_JITO_BUNDLE=

# Helius Sender endpoint overrides. Prefer region routing unless you know
# you need to pin a specific endpoint.
HELIUS_SENDER_ENDPOINT=
HELIUS_SENDER_BASE_URL=

# Hello Moon QUIC endpoint override. Expected format: host:port.
HELLOMOON_QUIC_ENDPOINT=

# Enable Hello Moon QUIC MEV protection. Supported true values: 1, true, yes, on.
HELLOMOON_MEV_PROTECT=

# Jito Bundle endpoint overrides. Deferred provider path; not recommended in
# setup guides until re-tested.
JITO_BUNDLE_BASE_URLS=
JITO_SEND_BUNDLE_ENDPOINT=
JITO_BUNDLE_STATUS_ENDPOINT=

# ------------------------------------------------------------
# Provider / launchpad integrations
# ------------------------------------------------------------

HELLOMOON_API_KEY=
BAGS_API_KEY=
BAGS_API_BASE_URL=

# Pass Rust-cached blockhash values into Bags prepare/build-launch requests.
# Blank defaults to enabled.
LAUNCHDECK_BAGS_HELPER_BLOCKHASH_FROM_RUST=

# Bags setup transaction tip and confirmation controls.
LAUNCHDECK_BAGS_SETUP_JITO_TIP_MIN_LAMPORTS=
LAUNCHDECK_BAGS_SETUP_JITO_TIP_CAP_LAMPORTS=
LAUNCHDECK_BAGS_SETUP_CONFIRM_TIMEOUT_SECS=
LAUNCHDECK_BAGS_SETUP_GATE_COMMITMENT=

# ------------------------------------------------------------
# Metadata upload
# ------------------------------------------------------------

LAUNCHDECK_METADATA_UPLOAD_PROVIDER=
PINATA_JWT=

# ------------------------------------------------------------
# Warmup / keep-warm
# ------------------------------------------------------------

# Startup warm and continuous warm default to enabled.
LAUNCHDECK_ENABLE_STARTUP_WARM=
LAUNCHDECK_ENABLE_CONTINUOUS_WARM=
LAUNCHDECK_ENABLE_IDLE_WARM_SUSPEND=

# Operators with very high RPC budgets can keep warm loops and balance streams
# active even while idle. Blank/default keeps credit-saving idle suspension.
TRADING_RESOURCE_MODE=

LAUNCHDECK_IDLE_WARM_TIMEOUT_MS=
LAUNCHDECK_CONTINUOUS_WARM_INTERVAL_MS=
LAUNCHDECK_CONTINUOUS_WARM_PASS_TIMEOUT_MS=
LAUNCHDECK_WARM_PROBE_TIMEOUT_MS=
LAUNCHDECK_DISABLE_STARTUP_WARM=
LAUNCHDECK_LAUNCHPAD_WARM_CONTEXT=
LAUNCHDECK_LAUNCHPAD_PARALLEL_WARM_FETCH=
LAUNCHDECK_LAUNCHPAD_WARM_MAX_PARALLEL_FETCH=

# Extension execution-engine per-family warm controls.
EXECUTION_ENGINE_WARM_PUMP=
EXECUTION_ENGINE_WARM_RAYDIUM_AMM_V4=
EXECUTION_ENGINE_WARM_RAYDIUM_CPMM=
EXECUTION_ENGINE_WARM_RAYDIUM_LAUNCHLAB=
EXECUTION_ENGINE_WARM_BONK=
EXECUTION_ENGINE_WARM_BAGS=
EXECUTION_ENGINE_WARM_TRUSTED_STABLE_SWAP=

# Launchpad startup warm backend overrides. Advanced/debug only.
LAUNCHDECK_BONK_STARTUP_WARM_BACKEND=
LAUNCHDECK_BAGSAPP_STARTUP_WARM_BACKEND=

# Bonk USD1 route tuning. Leave blank unless debugging Bonk USD1 route setup.
BONK_USD1_ROUTE_SETUP_CACHE_TTL_MS=
BONK_USD1_SEARCH_TOLERANCE_BPS=
BONK_USD1_SEARCH_MIN_LAMPORTS=
BONK_USD1_MIN_REMAINING_SOL=
BONK_USD1_MAX_INPUT_SEARCH_ITERATIONS=

# ------------------------------------------------------------
# Block height / follow timing
# ------------------------------------------------------------

LAUNCHDECK_BLOCK_HEIGHT_CACHE_TTL_MS=
LAUNCHDECK_BLOCK_HEIGHT_SAMPLE_MAX_AGE_MS=
LAUNCHDECK_FOLLOW_OFFSET_POLL_INTERVAL_MS=
LAUNCHDECK_ENABLE_APPROXIMATE_FOLLOW_OFFSET_TIMER=

# Legacy / no-op after the offset-worker migration. Safe to delete from local envs.
LAUNCHDECK_FOLLOW_BLOCK_HEIGHT_REFRESH_MS=

# ------------------------------------------------------------
# Reporting / traffic / UI cadence
# ------------------------------------------------------------

# off | light | full. Blank defaults to full.
LAUNCHDECK_BENCHMARK_MODE=

LAUNCHDECK_TRACK_SEND_BLOCK_HEIGHT=
LAUNCHDECK_RPC_TRAFFIC_METER=
LAUNCHDECK_WALLET_STATUS_REFRESH_INTERVAL_MS=

# ------------------------------------------------------------
# Auto Fee estimates
# ------------------------------------------------------------

# AUTO_FEE_BUFFER_PERCENT defaults to 10.
# HELIUS_PRIORITY_LEVEL defaults to high.
# HELIUS_PRIORITY_REFRESH_INTERVAL_MS defaults to 30000ms.
# HELIUS_PRIORITY_STALE_MS defaults to 45000ms.
# JITO_TIP_PERCENTILE defaults to p99.
# JITO_TIP_REFRESH_INTERVAL_MS defaults to 2000ms and mostly controls reconnect delay.
# JITO_TIP_STALE_MS defaults to 45000ms.
AUTO_FEE_BUFFER_PERCENT=
HELIUS_PRIORITY_LEVEL=
HELIUS_PRIORITY_REFRESH_INTERVAL_MS=
HELIUS_PRIORITY_STALE_MS=
JITO_TIP_PERCENTILE=
JITO_TIP_REFRESH_INTERVAL_MS=
JITO_TIP_STALE_MS=

# Legacy aliases are still accepted, but new setups should use the names above.
# LAUNCHDECK_AUTO_FEE_HELIUS_PRIORITY_LEVEL=
# LAUNCHDECK_HELIUS_PRIORITY_REFRESH_INTERVAL_MS=
# LAUNCHDECK_AUTO_FEE_JITO_TIP_PERCENTILE=
# TRENCH_AUTO_FEE_BUFFER_PERCENT=

# ------------------------------------------------------------
# Voluntary support fee / wrapper controls
# ------------------------------------------------------------

# User-facing voluntary fee setting.
# Blank/default = 0.1%, 0 = off, 0.2 = increased support.
TRENCH_TOOL_FEE=

# Legacy alias. Still accepted for existing installs, but prefer TRENCH_TOOL_FEE.
# Values are basis points: blank/10 = 0.1%, 0 = off, 20 = 0.2%.
EXECUTION_ENGINE_WRAPPER_DEFAULT_FEE_BPS=

# Emit per-transaction ALT coverage diagnostics to logs.
ALT_COVERAGE_DIAGNOSTICS=

# ------------------------------------------------------------
# Execution-engine rollout / safety switches
# ------------------------------------------------------------

EXECUTION_ENGINE_ENABLE_PUMP_NATIVE=
EXECUTION_ENGINE_ENABLE_RAYDIUM_AMM_V4_NATIVE=
EXECUTION_ENGINE_ENABLE_RAYDIUM_CPMM_NATIVE=
EXECUTION_ENGINE_ENABLE_RAYDIUM_LAUNCHLAB_NATIVE=
EXECUTION_ENGINE_ENABLE_BONK_NATIVE=
EXECUTION_ENGINE_ENABLE_METEORA_NATIVE=
EXECUTION_ENGINE_ENABLE_TRUSTED_STABLE_SWAP=
EXECUTION_ENGINE_ALLOW_NON_CANONICAL_POOL_TRADES=

# Pump bonding-curve creator-vault Custom(2006) recovery.
# Blank/default = enabled. Set false/0/no/off to disable the one-shot retry.
EXECUTION_ENGINE_ENABLE_PUMP_CREATOR_VAULT_AUTO_RETRY=

# ------------------------------------------------------------
# Follow daemon transport / capacity
# ------------------------------------------------------------

LAUNCHDECK_FOLLOW_DAEMON_TRANSPORT=
LAUNCHDECK_FOLLOW_DAEMON_URL=
LAUNCHDECK_FOLLOW_DAEMON_PORT=
LAUNCHDECK_FOLLOW_MAX_ACTIVE_JOBS=
LAUNCHDECK_FOLLOW_MAX_CONCURRENT_COMPILES=
LAUNCHDECK_FOLLOW_MAX_CONCURRENT_SENDS=
LAUNCHDECK_FOLLOW_CAPACITY_WAIT_MS=
LAUNCHDECK_SOL_USD_HTTP_PRICE_URL=

# Pump creator-vault retry controls. Both default to enabled.
LAUNCHDECK_ENABLE_PUMP_BUY_CREATOR_VAULT_AUTO_RETRY=
LAUNCHDECK_ENABLE_PUMP_SELL_CREATOR_VAULT_AUTO_RETRY=

# ------------------------------------------------------------
# Compute / slippage overrides
# ------------------------------------------------------------

TRUSTED_STABLE_SWAP_MAX_SLIPPAGE_BPS=
LAUNCHDECK_LAUNCH_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_AGENT_SETUP_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_FOLLOW_UP_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_SNIPER_BUY_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_DEV_AUTO_SELL_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_LAUNCH_USD1_TOPUP_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_BONK_USD1_SELL_TO_SOL_COMPUTE_UNIT_LIMIT=

# ------------------------------------------------------------
# Local state path overrides
# ------------------------------------------------------------
#
# The unified launcher sets these under TRENCH_TOOLS_DATA_ROOT.
# Only set them if you run binaries manually or intentionally need custom paths.

LAUNCHDECK_LOCAL_DATA_DIR=
LAUNCHDECK_SEND_LOG_DIR=
LAUNCHDECK_ENGINE_RUNTIME_PATH=
LAUNCHDECK_FOLLOW_DAEMON_STATE_PATH=

# Shared bearer token escape hatches. Most users should use the default file:
# .local/trench-tools/default-engine-token.txt
LAUNCHDECK_EXECUTION_ENGINE_TOKEN=
LAUNCHDECK_EXECUTION_ENGINE_TOKEN_FILE=

# ------------------------------------------------------------
# Developer script compatibility
# ------------------------------------------------------------

# Compatibility alias used by some standalone helper scripts.
RPC_URL=
